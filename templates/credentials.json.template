{
  "_comment": "Oh-My-OpenCode 凭证配置文件 - 请填写您的实际凭证",
  
  "model_service": {
    "api_key": "YOUR_API_KEY_HERE",
    "base_url": "https://YOUR_SERVICE_URL/v1"
  },
  
  "database": {
    "default": {
      "type": "mysql",
      "host": "localhost",
      "port": 3306,
      "user": "root",
      "password": "YOUR_PASSWORD_HERE",
      "database": "YOUR_DATABASE_NAME"
    }
  },
  
  "deploy": {
    "aliyun_fc": {
      "enabled": false,
      "access_key_id": "YOUR_ALIYUN_ACCESS_KEY_ID",
      "access_key_secret": "YOUR_ALIYUN_ACCESS_KEY_SECRET",
      "region": "cn-shanghai"
    },
    "docker": {
      "enabled": false,
      "registry": "registry.cn-shanghai.aliyuncs.com",
      "namespace": "YOUR_NAMESPACE",
      "username": "YOUR_USERNAME",
      "password": "YOUR_PASSWORD"
    },
    "server": {
      "enabled": false,
      "host": "YOUR_SERVER_IP",
      "port": 22,
      "username": "root",
      "auth_type": "key",
      "key_path": "~/.ssh/id_rsa",
      "password": ""
    },
    "vercel": {
      "enabled": false,
      "token": "YOUR_VERCEL_TOKEN"
    }
  },
  
  "image_generator": {
    "enabled": false,
    "api_key": "YOUR_SD_API_KEY",
    "base_url": "https://YOUR_SD_SERVICE_URL"
  },
  
  "notification": {
    "desktop": {
      "enabled": true,
      "sound": true
    },
    "webhook": {
      "enabled": false,
      "platform": "wecom",
      "webhook_url": "YOUR_WEBHOOK_URL",
      "secret": ""
    },
    "triggers": ["task_complete", "need_input", "error"]
  }
}
